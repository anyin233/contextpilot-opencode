{
  "name": "contextpilot-opencode",
  "version": "0.2.0",
  "description": "ContextPilot plugin for OpenCode — per-turn context optimization via lossless deduplication of repeated tool outputs.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "ContextPilot Contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anyin233/contextpilot-opencode.git"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "contextpilot",
    "context-optimization",
    "context-reuse",
    "token-savings",
    "dedup",
    "llm"
  ],
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tui": "./src/tui.tsx"
  },
  "scripts": {
    "test": "bun test ./src",
    "typecheck": "tsc --noEmit",
    "build": "bun run clean && tsc",
    "clean": "bun -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\""
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/index.ts",
    "src/tui.tsx",
    "src/stats.ts",
    "src/engine/"
  ],
  "peerDependencies": {
    "@opencode-ai/plugin": "*",
    "@opentui/core": "*",
    "@opentui/solid": "*",
    "solid-js": "*"
  },
  "peerDependenciesMeta": {
    "@opentui/core": {
      "optional": true
    },
    "@opentui/solid": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.14.41",
    "@opentui/core": "^0.3.4",
    "@opentui/solid": "^0.3.4",
    "@types/bun": "^1.3.4",
    "@types/node": "^24.10.1",
    "effect": "4.0.0-beta.59",
    "solid-js": "1.9.12",
    "typescript": "^5.9.3"
  },
  "bugs": {
    "url": "https://github.com/anyin233/contextpilot-opencode/issues"
  },
  "homepage": "https://github.com/anyin233/contextpilot-opencode#readme"
}
